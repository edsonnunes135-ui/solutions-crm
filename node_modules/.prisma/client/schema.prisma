generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  whatsapp
  instagram
}

enum Role {
  owner
  admin
  agent
  viewer
}

enum TaskStatus {
  open
  done
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             Membership[]
  contacts          Contact[]
  conversations     Conversation[]
  messages          Message[]
  pipelines         Pipeline[]
  stages            Stage[]
  deals             Deal[]
  tasks             Task[]
  tags              Tag[]
  events            Event[]
  automations       Automation[]
  automationRuns    AutomationRun[]
  contactTags       ContactTag[]
  contactIdentities ContactIdentity[]
  channelAccounts   ChannelAccount[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  ownedDeals  Deal[]       @relation("DealOwner")
  tasks       Task[]       @relation("TaskAssignee")
}

model Membership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      Role     @default(agent)
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model Contact {
  id        String       @id @default(cuid())
  orgId     String
  name      String
  company   String?
  phone     String?
  email     String?
  tags      ContactTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  deals         Deal[]
  tasks         Task[]
  identities    ContactIdentity[]
}

model Conversation {
  id         String   @id @default(cuid())
  orgId      String
  contactId  String
  channel    Channel
  externalId String? // id do canal (wa thread / ig thread)
  status     String   @default("open")
  lastAt     DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact  Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([orgId, channel, externalId])
  @@index([orgId, channel])
}

model Message {
  id             String   @id @default(cuid())
  orgId          String
  conversationId String
  channel        Channel
  direction      String // inbound/outbound
  text           String
  externalId     String?
  sentAt         DateTime @default(now())

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([orgId, externalId])
  @@index([orgId, conversationId])
}

model Pipeline {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  kind      String   @default("sales") // sales, support, warming, reactivation, nonlead
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stages Stage[]
  deals  Deal[]
}

model Stage {
  id         String   @id @default(cuid())
  orgId      String
  pipelineId String
  name       String
  order      Int
  createdAt  DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipeline Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, order])
}

model Deal {
  id         String   @id @default(cuid())
  orgId      String
  contactId  String
  pipelineId String
  stageId    String
  title      String
  value      Int      @default(0)
  status     String   @default("open") // open/won/lost
  ownerId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tasks      Task[]

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact  Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage    Stage        @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner    User?        @relation("DealOwner", fields: [ownerId], references: [id])

  @@index([orgId, pipelineId, stageId])
}

model Task {
  id         String     @id @default(cuid())
  orgId      String
  contactId  String?
  dealId     String?
  title      String
  dueAt      DateTime?
  status     TaskStatus @default(open)
  priority   String     @default("medium") // low/medium/high
  assigneeId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact  Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal     Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignee User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model Tag {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([orgId, name])
}

model ContactTag {
  id        String @id @default(cuid())
  orgId     String
  contactId String
  tagId     String

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
}

model ContactIdentity {
  id         String   @id @default(cuid())
  orgId      String
  contactId  String
  channel    Channel
  externalId String // id do usuário no canal (wa_id / ig sender id)
  username   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel, externalId])
  @@index([orgId, contactId])
}

model ChannelAccount {
  id                String   @id @default(cuid())
  orgId             String
  channel           Channel
  externalAccountId String // WhatsApp: phone_number_id | Instagram: recipient/page/ig id
  displayName       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel, externalAccountId])
  @@index([channel, externalAccountId])
}

model Event {
  id        String   @id @default(cuid())
  orgId     String
  type      String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type, processed])
}

model Automation {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  enabled       Boolean  @default(true)
  triggerType   String // message_received, stage_changed, no_reply, stale_stage...
  triggerConfig Json // JSON livre (ex.: {channel:"whatsapp", minutes:15})
  conditions    Json // JSON livre (ex.: {tagIn:[...], scoreGte:70})
  actions       Json // JSON livre (ex.: [{type:"create_task", ...}, {type:"send_msg", ...}])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  runs AutomationRun[]
}

model AutomationRun {
  id           String   @id @default(cuid())
  orgId        String
  automationId String
  eventId      String?
  status       String   @default("success") // success/error/skipped
  log          String?
  createdAt    DateTime @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  automation Automation   @relation(fields: [automationId], references: [id], onDelete: Cascade)
}
